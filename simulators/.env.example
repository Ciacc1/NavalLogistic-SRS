# Environment file di esempio per i simulatori
# Copia a .env e personalizza se necessario

# Fleet Simulator
FLEET_KAFKA_BROKERS=kafka:29092
FLEET_LOG_LEVEL=info
FLEET_UPDATE_INTERVAL=5000

# Cargo Simulator
CARGO_KAFKA_BROKERS=kafka:29092
CARGO_LOG_LEVEL=info
CARGO_UPDATE_INTERVAL=5000

# Disaster Simulator
DISASTER_PORT=3001
DISASTER_LOG_LEVEL=info

# Kafka
KAFKA_BROKERS=kafka:29092
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181

# Database/Persistence (opzionale per il futuro)
# MONGO_URI=mongodb://mongo:27017
# REDIS_HOST=redis
# REDIS_PORT=6379

# API Gateway (opzionale)
# API_GATEWAY_URL=http://localhost:8000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
